# ═══════════════════════════════════════════════════════
#  Tajik Music CRM — Переменные окружения
#  Скопируй в корень проекта: cp deploy/.env.example .env
#  и заполни значения
# ═══════════════════════════════════════════════════════

# База данных PostgreSQL
# Возьми из /root/db_credentials.txt (создан скриптом 1_setup.sh)
DATABASE_URL=postgresql://tajikmusic_user:YOUR_PASSWORD@localhost:5432/tajikmusic

# Окружение
NODE_ENV=production

# Секретный ключ для сессий (любая длинная случайная строка)
# Сгенерировать: openssl rand -base64 48
SESSION_SECRET=replace_with_long_random_string_here

# Порт API-сервера (не менять — Nginx проксирует на этот порт)
API_PORT=3001

# Домен (без http://)
DOMAIN=your-domain.com
