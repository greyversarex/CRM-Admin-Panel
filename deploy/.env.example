# ═══════════════════════════════════════════════════════
#  Tajik Music CRM — Переменные окружения
#  Скопируй в корень проекта: cp deploy/.env.example /var/www/tajikmusic/.env
#  и заполни значения
# ═══════════════════════════════════════════════════════

# ── База данных PostgreSQL ──────────────────────────────
# Возьми из /root/db_credentials.txt (создан скриптом 1_setup.sh)
# Формат: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://tajikmusic_user:YOUR_PASSWORD@localhost:5432/tajikmusic

# ── Окружение ───────────────────────────────────────────
NODE_ENV=production

# ── Секрет сессий ───────────────────────────────────────
# Сгенерируй один раз: openssl rand -base64 48
# При смене все юзеры разлогинятся!
SESSION_SECRET=replace_with_long_random_string_here

# ── Порт API-сервера ────────────────────────────────────
# Nginx проксирует /api/ → 127.0.0.1:PORT
PORT=3001

# ── Базовый путь фронта (на сборке) ─────────────────────
# Если фронт на корне домена — оставь /
# Если в подпути (https://example.com/crm/) — пиши /crm/
BASE_PATH=/

# ── Домен (для документации; в приложении не используется) ──
DOMAIN=your-domain.com
