# ═══════════════════════════════════════════════════════
#  Tajik Music CRM — Переменные окружения
#  Скопируй в корень проекта: cp deploy/.env.example /var/www/tajikmusic/.env
#  и заполни значения
# ═══════════════════════════════════════════════════════

# ── База данных PostgreSQL ──────────────────────────────
# Возьми из /root/db_credentials.txt (создан скриптом 1_setup.sh)
# Формат: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://tajikmusic_user:YOUR_PASSWORD@localhost:5432/tajikmusic

# ── Окружение ───────────────────────────────────────────
NODE_ENV=production

# ── Секрет сессий ───────────────────────────────────────
# Сгенерируй один раз: openssl rand -base64 48
# При смене все юзеры разлогинятся!
SESSION_SECRET=replace_with_long_random_string_here

# ── Порт API-сервера ────────────────────────────────────
# Nginx проксирует /api/ → 127.0.0.1:PORT
PORT=3001

# ── Базовый путь фронта (на сборке) ─────────────────────
# Если фронт на корне домена — оставь /
# Если в подпути (https://example.com/crm/) — пиши /crm/
BASE_PATH=/

# ── Разрешённые origin'ы для CORS ──────────────────────
# CSV-список адресов, с которых браузер разрешено стучаться в API.
# В проде ОБЯЗАТЕЛЬНО заполнить — иначе фронт получит "CORS: origin not allowed".
# Примеры:
#   WEB_ORIGINS=http://203.0.113.42                 — пока есть только IP
#   WEB_ORIGINS=https://crm.example.com             — после подключения домена + HTTPS
#   WEB_ORIGINS=https://crm.example.com,http://203.0.113.42  — несколько адресов
# Без http:// / https:// и без слэша на конце!
WEB_ORIGINS=http://YOUR_SERVER_IP_OR_DOMAIN

# ── Локальное хранилище загруженных файлов ─────────────
# Каталог, куда сервер пишет обложки релизов, аудио треков, аватары и KYC-документы.
# Должен быть ВНЕ каталога деплоя (чтобы git pull / rebuild не стирал файлы)
# и доступен на запись пользователю, под которым работает API (см. pm2 / docker).
LOCAL_STORAGE_ROOT=/var/lib/tajikmusic/uploads

# ── Домен (для документации; в приложении не используется) ──
DOMAIN=your-domain.com
